# Default-deny: only keep app source + Gradle build files in the repo.
/*

# Keep repository essentials
!/.gitignore
!/README.md
!/LICENSE
!/.gitattributes
!/PRIVACY-POLICY

# Keep Gradle project files
!/build.gradle.kts
!/settings.gradle.kts
!/gradle.properties
!/gradlew
!/gradlew.bat
!/gradle/
!/gradle/**

# Keep Android app module
!/app/
!/app/**

# ── IDE & tool caches ──────────────────────────────────────────────────────
/.idea/
/.vscode/
/.gradle/
/.kotlin/
/.configuration-cache/

# ── Build output ───────────────────────────────────────────────────────────
/build/
**/build/
**/generated/
**/intermediates/
**/outputs/
**/tmp/
**/.externalNativeBuild/
**/.cxx/

# ── AI assistant workspace state (Claude Code) ─────────────────────────────
/.claude/
/.remember/

# ── Dev-machine resources (notes, logs, old code, research) ────────────────
# Not required for compilation; kept locally only.
/RESOURCES/
/PlayStore_Resources/

# ── Signing secrets & local machine config ─────────────────────────────────
/local.properties
/keystore.properties
*.jks
*.keystore
*.p12
*.pfx
*.pem
*.key
*.der
*.csr
*.crt

# ── Crash dumps, logs, and ephemeral dev artefacts ─────────────────────────
*.log
*.tmp
*.temp
*.swp
*.swo
*.bak
*~
*.hprof
hs_err_pid*.log
replay_pid*.log

# ── Python tooling artefacts (llama.cpp build/test scripts) ────────────────
**/__pycache__/
**/*.pyc
**/*.pyo

# ── Large runtime model assets (not required for source builds) ────────────
*.gguf
*.safetensors
app/src/main/assets/models/
