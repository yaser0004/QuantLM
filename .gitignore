# Default-deny: only keep app source + Gradle build files in the repo.
/*

# Keep repository essentials
!/.gitignore
!/README.md
!/LICENSE

# Keep Gradle project files
!/build.gradle.kts
!/settings.gradle.kts
!/gradle.properties
!/gradlew
!/gradlew.bat
!/gradle/
!/gradle/**

# Keep Android app module
!/app/
!/app/**

# Exclude local IDE/build caches even inside allowed folders
/.idea/
/.vscode/
/.gradle/
/.kotlin/
/.configuration-cache/
/build/
**/build/
**/generated/
**/intermediates/
**/outputs/
**/tmp/
**/.externalNativeBuild/
**/.cxx/

# Local machine and signing secrets
/local.properties
/keystore.properties
*.jks
*.keystore
*.p12
*.pfx
*.pem
*.key
*.der
*.csr
*.crt

# Local logs, crash dumps, and diagnostics
*.log
*.tmp
*.temp
*.swp
*.swo
*.bak
*~
*.hprof
hs_err_pid*.log
replay_pid*.log
/build_error.txt
/build_error_utf8.txt
/bundle_release.log
/file_list.txt
/quantlm_ui.xml
/release_crash_analysis.md

# Large runtime model assets (not required for source builds)
*.gguf
*.safetensors
app/src/main/assets/models/
