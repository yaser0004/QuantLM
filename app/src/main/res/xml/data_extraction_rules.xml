<?xml version="1.0" encoding="utf-8"?><!--
   Backup / device-transfer rules for API 31+. Everything not excluded is
   included. See backup_rules.xml (the API <= 30 twin) for the rationale of
   each exclude; the two files must be kept in sync.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="models" />
        <exclude domain="file" path="diagnostics" />
        <exclude domain="file" path="datastore" />
        <exclude domain="sharedpref" path="huggingface_auth.xml" />
        <exclude domain="sharedpref" path="quantlm_lock_state.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="models" />
        <exclude domain="file" path="diagnostics" />
        <exclude domain="file" path="datastore" />
        <exclude domain="sharedpref" path="huggingface_auth.xml" />
        <exclude domain="sharedpref" path="quantlm_lock_state.xml" />
    </device-transfer>
</data-extraction-rules>
